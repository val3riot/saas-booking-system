#!/usr/bin/env sh
set -eu

MVNW_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
MAVEN_VERSION="${MAVEN_VERSION:-3.9.9}"
MAVEN_HOME="$MVNW_DIR/.mvn/apache-maven-$MAVEN_VERSION"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  mkdir -p "$MVNW_DIR/.mvn"
  ARCHIVE="$MVNW_DIR/.mvn/apache-maven-$MAVEN_VERSION-bin.tar.gz"
  URL="https://archive.apache.org/dist/maven/maven-3/$MAVEN_VERSION/binaries/apache-maven-$MAVEN_VERSION-bin.tar.gz"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$URL" -o "$ARCHIVE"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$URL" -O "$ARCHIVE"
  else
    echo "curl or wget is required to bootstrap Maven." >&2
    exit 1
  fi
  tar -xzf "$ARCHIVE" -C "$MVNW_DIR/.mvn"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
