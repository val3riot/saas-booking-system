# Activate local development defaults and Swagger/OpenAPI.
SPRING_PROFILES_ACTIVE=dev

# Local infrastructure.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/booking
SPRING_DATASOURCE_USERNAME=booking
SPRING_DATASOURCE_PASSWORD=booking
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CONNECT_TIMEOUT=1s
REDIS_COMMAND_TIMEOUT=2s

# Development-only JWT settings. Always use a strong secret outside local development.
JWT_SECRET=dev-only-secret-change-before-production
JWT_EXPIRATION=86400000
JWT_ISSUER=saas-booking-system
JWT_AUDIENCE=saas-booking-api

# Optional cache TTL overrides.
CACHE_TTL_PROVIDER_SEARCH=5m
CACHE_TTL_PROVIDER_DETAILS=15m
CACHE_TTL_PROVIDER_SERVICES=10m
CACHE_TTL_SERVICE_DETAILS=10m

# Set to true only when Spring Boot should start the local Compose services.
SPRING_DOCKER_COMPOSE_ENABLED=false
